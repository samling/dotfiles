local wezterm = require('wezterm')

local config = wezterm.config_builder()

--
-- windows
--
{{ if eq .chezmoi.os "windows"}}
local base_font_size = 10.5
config.animation_fps = 255
config.wsl_domains = {
    {
        name = "WSL:Ubuntu",
        distribution = "Ubuntu",
        default_cwd = "~"
    },
}
config.front_end = 'WebGpu' -- WebGpu or OpenGL
config.default_domain = "WSL:Ubuntu"
config.font = wezterm.font('Iosevka', { weight = 'Regular', stretch = 'Normal' })
{{ end }}

--
-- macos
--
{{ if eq .chezmoi.os "darwin" }}
local base_font_size = 16
config.animation_fps = 120
config.font = wezterm.font_with_fallback {'Iosevka', 'Iosevka Nerd Font Propo'}
config.window_decorations = "RESIZE"
{{ end }}

--
-- linux
--
{{ if eq .chezmoi.os "linux" }}
local base_font_size = 12
config.animation_fps = 120
config.font = wezterm.font 'Iosevka'
-- config.font = wezterm.font_with_fallback {'Iosevka', 'Iosevka Nerd Font Propo'}
{{ end }}

config.font_size = base_font_size

-- enabling kitty keyboard fixes certain keybindings on windows and linux
{{ if ne .chezmoi.os "darwin" }}
config.enable_kitty_keyboard = true
{{ end }}

config.enable_wayland = false
config.enable_tab_bar = false

config.window_padding = {
  bottom = 0,
}

config.color_scheme = "Catppuccin Mocha"
config.warn_about_missing_glyphs=false

config.disable_default_key_bindings=true
config.keys = {
  -- Make Option-Left equivalent to Alt-b which many line editors interpret as backward-word
  {key="LeftArrow", mods="OPT", action=wezterm.action{SendString="\x1bb"}},
  -- Make Option-Right equivalent to Alt-f; forward-word
  {key="RightArrow", mods="OPT", action=wezterm.action{SendString="\x1bf"}},
{ key = '=', mods = 'CTRL', action = wezterm.action.IncreaseFontSize },
{ key = '-', mods = 'CTRL', action = wezterm.action.DecreaseFontSize },
{ key = '0', mods = 'CTRL', action = wezterm.action.ResetFontSize },
  {
    key = "P",
    mods = "CTRL|SHIFT",
    action = wezterm.action.ActivateCommandPalette,
  },
  {
    key = "C",
    mods = "CTRL|SHIFT",
    action = wezterm.action.CopyTo('Clipboard'),
  },
  {
    key = "V",
    mods = "CTRL|SHIFT",
    action = wezterm.action.PasteFrom('Clipboard'),
  },
  {{ if eq .chezmoi.os "darwin" }}
  {
    key = "P",
    mods = "CMD|SHIFT",
    action = wezterm.action.ActivateCommandPalette,
  },
  {
    key = "C",
    mods = "CMD|SHIFT",
    action = wezterm.action.CopyTo('Clipboard'),
  },
  {
    key = "C",
    mods = "CMD",
    action = wezterm.action.CopyTo('Clipboard'),
  },
  {
    key = "V",
    mods = "CMD|SHIFT",
    action = wezterm.action.PasteFrom('Clipboard'),
  },
  {
    key = "V",
    mods = "CMD",
    action = wezterm.action.PasteFrom('Clipboard'),
  },
  {{ end }}
}

{{- $hostname := .chezmoi.hostname -}}
{{- $weztermCfg := dict -}}
{{- if and (hasKey . "host") (hasKey .host $hostname) (hasKey (index .host $hostname) "appconfig") (hasKey (index .host $hostname).appconfig "wezterm") -}}
{{-   $weztermCfg = (index .host $hostname).appconfig.wezterm -}}
{{- end -}}
{{- if hasKey $weztermCfg "font_size" }}
config.font_size = {{ $weztermCfg.font_size }}
{{- else }}
-- Scale font size based on screen resolution
wezterm.on('window-config-reloaded', function(window, pane)
  local overrides = window:get_config_overrides() or {}
  local screen = wezterm.gui.screens().active
  local scale = screen.width / 1920
  if scale < 1.2 then scale = 1 end
  local target_size = base_font_size * scale
  if overrides.font_size ~= target_size then
    overrides.font_size = target_size
    window:set_config_overrides(overrides)
  end
end)
{{- end }}

return config
