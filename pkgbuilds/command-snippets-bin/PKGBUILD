pkgname=command-snippets-bin
_pkgname=cs
pkgver=0.1.2
pkgrel=1
pkgdesc="Fuzzy-searchable command snippet manager"
arch=('x86_64' 'aarch64')
url="https://github.com/samling/command-snippets"
license=('custom')
provides=('command-snippets' 'cs')
conflicts=('command-snippets' 'cs')
source_x86_64=("$pkgname-$pkgver-x86_64.tar.gz::$url/releases/download/v$pkgver/${_pkgname}-v${pkgver}-linux-amd64.tar.gz")
source_aarch64=("$pkgname-$pkgver-aarch64.tar.gz::$url/releases/download/v$pkgver/${_pkgname}-v${pkgver}-linux-arm64.tar.gz")
sha256sums_x86_64=('004426ea59e08cda840b1f60df8040d7989aa9e8a9fb726c8e8b22c2ae7f9c82')
sha256sums_aarch64=('3d082752d5a0dbc65207291cc38f5f26515bc2861b05232abe941ecf1a1ae07b')

package() {
    install -Dm755 "$srcdir/${_pkgname}" "$pkgdir/usr/bin/${_pkgname}"
}
