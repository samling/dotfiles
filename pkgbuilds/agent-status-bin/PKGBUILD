# Maintainer: Sam Boynton <sboynton@nvidia.com>
pkgname=agent-status-bin
_pkgname=agent-status
pkgver=0.4.1
pkgrel=1
pkgdesc="API and live status board for AI agent session management"
arch=('x86_64' 'aarch64')
url="https://github.com/samling/agent-status"
license=('unknown')
provides=('agent-status')
conflicts=('agent-status')
source=("agent-status.service")
source_x86_64=("$pkgname-$pkgver-x86_64.tar.gz::$url/releases/download/v$pkgver/${_pkgname}_${pkgver}_linux-amd64.tar.gz")
source_aarch64=("$pkgname-$pkgver-aarch64.tar.gz::$url/releases/download/v$pkgver/${_pkgname}_${pkgver}_linux-arm64.tar.gz")
sha256sums=('c7c29b11e6efade28b11007cd1ebb6755530870a36d3e2659c56ff8debf52c57')
sha256sums_x86_64=('23bf60010fa8dc6ea7fab8e2a3ae280cd1a8c8e755cf113eebe16ead06030d2b')
sha256sums_aarch64=('e28a3d9839a9366c29244ff12bfc992ffe2709dac09ddb35987577a3dd10e8a2')

package() {
    local _suffix
    [[ $CARCH == x86_64 ]] && _suffix=linux-amd64
    [[ $CARCH == aarch64 ]] && _suffix=linux-arm64
    local _dist="${_pkgname}_${pkgver}_${_suffix}"

    install -Dm755 "$srcdir/${_dist}/${_pkgname}" "$pkgdir/usr/bin/${_pkgname}"
    install -Dm644 "$srcdir/${_dist}/README.md" "$pkgdir/usr/share/doc/${pkgname}/README.md"
    install -Dm644 "$srcdir/agent-status.service" "$pkgdir/usr/lib/systemd/user/agent-status.service"
}
