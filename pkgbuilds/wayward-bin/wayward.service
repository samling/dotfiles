[Unit]
Description=wayward desktop shell in rust
Documentation=https://github.com/samling/wayward-rs
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ConfigurationDirectory=wayward
ExecStart=/usr/bin/wayward
Restart=on-failure
RestartSec=2

[Install]
WantedBy=graphical-session.target
