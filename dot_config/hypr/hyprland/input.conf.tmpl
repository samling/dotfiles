#############
### INPUT ###
#############

{{- $hostname := .chezmoi.hostname -}}
{{- $inputCfg := dict -}}
{{- if and (hasKey . "host") (hasKey .host $hostname) (hasKey (index .host $hostname) "appconfig") (hasKey (index .host $hostname).appconfig "hyprland") (hasKey (index .host $hostname).appconfig.hyprland "input") -}}
{{-   $inputCfg = (index .host $hostname).appconfig.hyprland.input -}}
{{- end }}

# https://wiki.hyprland.org/Configuring/Variables/#input
input {
    kb_layout = us
    kb_variant =
    kb_model =
    kb_options = numpad:mac
    kb_rules =

    follow_mouse = 1
    mouse_refocus = 0

    accel_profile = {{ if hasKey $inputCfg "accel_profile" }}{{ $inputCfg.accel_profile }}{{ else if eq .chassis.type "laptop" }}adaptive{{ else }}flat{{ end }}
    sensitivity = {{ if hasKey $inputCfg "sensitivity" }}{{ $inputCfg.sensitivity }}{{ else if eq .chassis.type "laptop" }}-0.5{{ else }}0{{ end }} # -1.0 - 1.0, 0 means no modification.

    touchpad {
        natural_scroll = true
        tap-to-click = false
        tap-and-drag = false
        clickfinger_behavior = true
        scroll_factor = 0.6
    }
}

################
### GESTURES ###
################

# https://wiki.hyprland.org/Configuring/Variables/#gestures
gesture = 3, horizontal, workspace
hyprexpo-gesture = 3, up, expo

gesture = 2, pinchin, dispatcher, exec, ~/.config/hypr/scripts/gestures.sh pinchin
gesture = 2, pinchout, dispatcher, exec, ~/.config/hypr/scripts/gestures.sh pinchout

###############
### DEVICES ###
###############

# See https://wiki.hyprland.org/Configuring/Keywords/#per-device-input-configs for more about per-device configs
{{ if eq .chassis.type "laptop" }}
device {
  name = elan067b:00-04f3:31f8-touchpad
  sensitivity = 0
}

device {
  name = tpps/2-elan-trackpoint
  sensitivity = 0
  accel_profile = flat
}

# Zenbook S16 trackpad
# device {
#   name = asuf1209:00-2808:0219-touchpad
#   sensitivity = 0
# }

# Disable touchscreen on x1 carbon
device {
  name = elan901c:00-04f3:2c29
  enabled = false
}

# Disable touchscreen on Zenbook S16
device {
  name = elan9008:00-04f3:433b
  enabled = false
}
{{ end }}
