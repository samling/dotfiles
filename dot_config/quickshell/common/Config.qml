    readonly property color pillColor6:  Qt.lighter(Colors.tertiary, 1.2)
    readonly property color pillColor7:  Qt.darker(Colors.primary, 1.2)
    readonly property color pillColor8:  Qt.darker(Colors.tertiary, 1.2)
