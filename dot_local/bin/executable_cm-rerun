#!/usr/bin/env bash
# Re-run chezmoi run_onchange scripts by clearing their state entries.
# Usage:
#   chezmoi-rerun              # interactive: pick from a list
#   chezmoi-rerun <pattern>    # clear all matching scripts, e.g. "install-packages"
#   chezmoi-rerun --all        # clear all script state

set -euo pipefail

if [[ "${1:-}" == "--all" ]]; then
  chezmoi state delete-bucket --bucket=scriptState
  echo "Cleared all script state. Run 'chezmoi apply' to re-run everything."
  exit 0
fi

# Get unique script names from state
mapfile -t entries < <(
  chezmoi state dump | python3 -c "
import sys, json
d = json.load(sys.stdin)
scripts = d.get('scriptState', {})
seen = {}
for key, val in scripts.items():
    name = val.get('name', key)
    if name not in seen:
        seen[name] = []
    seen[name].append(key)
for name in sorted(seen):
    keys = ' '.join(seen[name])
    print(f'{name}\t{keys}')
"
)

if [[ ${#entries[@]} -eq 0 ]]; then
  echo "No script state found."
  exit 0
fi

# If a pattern was given, filter and delete matching entries
if [[ -n "${1:-}" ]]; then
  pattern="$1"
  found=0
  for entry in "${entries[@]}"; do
    name="${entry%%	*}"
    keys="${entry#*	}"
    if [[ "$name" == *"$pattern"* ]]; then
      for key in $keys; do
        chezmoi state delete --bucket=scriptState --key="$key"
      done
      echo "Cleared: $name"
      found=1
    fi
  done
  if [[ $found -eq 0 ]]; then
    echo "No scripts matching '$pattern' found."
    exit 1
  fi
  echo "Run 'chezmoi apply' to re-run cleared scripts."
  exit 0
fi

# Interactive mode: show numbered list
echo "Scripts with saved state:"
echo ""
names=()
all_keys=()
for i in "${!entries[@]}"; do
  name="${entries[$i]%%	*}"
  keys="${entries[$i]#*	}"
  names+=("$name")
  all_keys+=("$keys")
  printf "  %2d) %s\n" $((i + 1)) "$name"
done

echo ""
read -rp "Enter number(s) to clear (comma-separated, or 'q' to quit): " selection

if [[ "$selection" == "q" ]]; then
  exit 0
fi

IFS=',' read -ra choices <<< "$selection"
for choice in "${choices[@]}"; do
  choice=$(echo "$choice" | tr -d ' ')
  idx=$((choice - 1))
  if [[ $idx -ge 0 && $idx -lt ${#names[@]} ]]; then
    for key in ${all_keys[$idx]}; do
      chezmoi state delete --bucket=scriptState --key="$key"
    done
    echo "Cleared: ${names[$idx]}"
  else
    echo "Invalid selection: $choice"
  fi
done
echo "Run 'chezmoi apply' to re-run cleared scripts."
