#!/usr/bin/env bash
cat | jq --arg home "$HOME" '
  .statusLine = {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  }
  | .sandbox.seccomp.bpfPath   = "\($home)/.local/share/claude-code/seccomp/x64/seccomp-unix-block.bpf"
  | .sandbox.seccomp.applyPath = "\($home)/.local/share/claude-code/seccomp/x64/apply-seccomp"
  | .sandbox.enabled = true
  | .sandbox.autoAllowBashIfSandboxed = true
'
