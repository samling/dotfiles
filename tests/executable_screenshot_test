#!/usr/bin/env bash

set -o errexit
set -o pipefail
set -o nounset

repo_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
script="$repo_root/chezmoi/dot_local/bin/executable_screenshot"
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

fakebin="$tmpdir/bin"
mkdir -p "$fakebin"

cat >"$fakebin/slurp" <<'EOF'
#!/usr/bin/env bash
printf '10,20 30x40\n'
EOF

cat >"$fakebin/niri" <<'EOF'
#!/usr/bin/env bash
if [ "$1" = "msg" ] && [ "$2" = "--json" ] && [ "$3" = "outputs" ]; then
  printf '{"eDP-1":{"logical":{"x":0,"y":0,"width":1920,"height":1200,"scale":1.5}}}\n'
  exit 0
fi
exit 1
EOF

cat >"$fakebin/grim" <<'EOF'
#!/usr/bin/env bash
out=${@: -1}
if [ "$out" = "-" ]; then
  printf 'raw screenshot\n'
else
  printf 'raw screenshot\n' >"$out"
fi
EOF

cat >"$fakebin/satty" <<'EOF'
#!/usr/bin/env bash
input=
output=
while [ "$#" -gt 0 ]; do
  case "$1" in
    --filename)
      input=$2
      shift 2
      ;;
    --output-filename)
      output=$2
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ "$input" = "-" ]; then
  cat >"$output"
else
  cp "$input" "$output"
fi
EOF

chmod +x "$fakebin/slurp" "$fakebin/niri" "$fakebin/grim" "$fakebin/satty"

mkdir -p "$tmpdir/pictures"
PATH="$fakebin:$PATH" XDG_PICTURES_DIR="$tmpdir/pictures" SCREENSHOT_DEBUG=1 bash "$script" region

mapfile -t finals < <(compgen -G "$tmpdir/pictures/Screenshots/Screenshot-*.png" | sort | while read -r file; do
  case "$file" in
    *.raw.png) ;;
    *) printf '%s\n' "$file" ;;
  esac
done)
mapfile -t raws < <(compgen -G "$tmpdir/pictures/Screenshots/Screenshot-*.raw.png" | sort)

if [ "${#finals[@]}" -ne 1 ]; then
  printf 'expected one final screenshot, found %s\n' "${#finals[@]}" >&2
  exit 1
fi

if [ "${#raws[@]}" -ne 1 ]; then
  printf 'expected one raw debug screenshot, found %s\n' "${#raws[@]}" >&2
  exit 1
fi

if ! cmp -s "${raws[0]}" "${finals[0]}"; then
  printf 'expected raw and final fixtures to match in fake pipeline\n' >&2
  exit 1
fi

printf 'ok - SCREENSHOT_DEBUG preserves raw region capture\n'
