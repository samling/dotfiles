#!/usr/bin/env bash

{{- $osID := .system.os_type -}}
{{- if ne $osID "darwin" }}

CHEZMOI_SOURCE="{{ .chezmoi.sourceDir }}"
STATE_DIR="$HOME/.local/state/chezmoi-etc"
mkdir -p "$STATE_DIR"

CHANGED=0

install_config() {
  local src="$1"
  local dest="$2"
  local state_file="$STATE_DIR/$(echo "$dest" | tr '/' '_')"
  local src_hash=$(sha256sum "$src" | cut -d' ' -f1)

  if [ -f "$dest" ]; then
    local current_hash=$(sha256sum "$dest" | cut -d' ' -f1)
    local deployed_hash=$(cat "$state_file" 2>/dev/null)

    if [ "$current_hash" = "$src_hash" ]; then
      return
    fi

    CHANGED=1

    if [ -n "$deployed_hash" ] && [ "$current_hash" != "$deployed_hash" ]; then
      echo "  WARNING: $dest was modified outside chezmoi!"
      diff -u "$dest" "$src" --color=auto --label "current $dest" --label "new $dest"
      read -rp "  Overwrite? [y/N] " answer
      [ "$answer" != "y" ] && return
    else
      echo "  $dest has changes:"
      diff -u "$dest" "$src" --color=auto --label "current $dest" --label "new $dest"
      read -rp "  Apply? [y/N] " answer
      [ "$answer" != "y" ] && return
    fi
  else
    CHANGED=1
    echo "  $dest is new"
  fi

  sudo install -Dm644 "$src" "$dest"
  sha256sum "$dest" | cut -d' ' -f1 > "$state_file"
}

install_config "$CHEZMOI_SOURCE/dot_config/regreet/config.toml" /etc/greetd/config.toml
install_config "$CHEZMOI_SOURCE/dot_config/regreet/regreet.toml" /etc/greetd/regreet.toml
install_config "$CHEZMOI_SOURCE/dot_config/keyd/default.conf" /etc/keyd/default.conf

if [ "$CHANGED" -gt 0 ]; then
  echo "[system-configs] Done."
fi

{{- end }}
