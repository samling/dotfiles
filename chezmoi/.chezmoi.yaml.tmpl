# Repo lives at ~/.local/share/dotfiles (matches the github repo
# name). The chezmoi source tree itself is in a `chezmoi/` subdir so
# the repo can also host decman, pkgbuilds, etc. without those being
# walked by chezmoi. The .chezmoiroot file at the repo root tells
# chezmoi to descend into chezmoi/.
sourceDir: {{ .chezmoi.homeDir }}/.local/share/dotfiles

