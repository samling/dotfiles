#!/usr/bin/env bash
set -euo pipefail
tmp=$(mktemp); trap 'rm -f "$tmp"' EXIT
cat > "$tmp"
for mime in image/jpeg image/png image/gif image/bmp image/webp image/tiff; do
  crudini --set "$tmp" "Default Applications" "$mime" imv.desktop
done
# Hand http(s) and friends to the Windows Chrome interop wrapper on WSL,
# so xdg-open / $BROWSER consumers (e.g. tsh) launch the host browser
# instead of a Linux Chrome under WSLg.
if [ -n "${WSL_DISTRO_NAME:-}" ]; then
  for mime in text/html x-scheme-handler/http x-scheme-handler/https x-scheme-handler/about x-scheme-handler/unknown; do
    crudini --set "$tmp" "Default Applications" "$mime" google-chrome.desktop
  done
fi
# xdg-mime's shell parser uses `grep "^key="` and won't match `key = value`,
# so strip the spaces crudini inserts.
sed -E 's/^([^=[:space:]]+)[[:space:]]*=[[:space:]]*/\1=/' "$tmp"
