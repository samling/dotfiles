{
  "name": "Matugen",
  "type": "dark",
  "colors": {
    "editor.background": "{{colors.background.default.hex}}",
    "editor.foreground": "{{colors.on_surface.default.hex}}",
    "editor.selectionBackground": "{{colors.primary_container.default.hex}}",
    "editor.lineHighlightBackground": "{{colors.surface_container_low.default.hex}}",
    "editor.inactiveSelectionBackground": "{{colors.surface_container.default.hex}}",
    "editorCursor.foreground": "{{colors.primary.default.hex}}",
    "editorWhitespace.foreground": "{{colors.outline_variant.default.hex}}",
    "editorLineNumber.foreground": "{{colors.outline_variant.default.hex}}",
    "editorLineNumber.activeForeground": "{{colors.on_surface.default.hex}}",
    "editorIndentGuide.background": "{{colors.surface_container_low.default.hex}}",
    "editorIndentGuide.activeBackground": "{{colors.outline_variant.default.hex}}",
    "editorBracketMatch.background": "{{colors.surface_container.default.hex}}",
    "editorBracketMatch.border": "{{colors.primary.default.hex}}",

    "activityBar.background": "{{colors.surface_container_lowest.default.hex}}",
    "activityBar.foreground": "{{colors.on_surface.default.hex}}",
    "activityBarBadge.background": "{{colors.primary.default.hex}}",
    "activityBarBadge.foreground": "{{colors.on_primary.default.hex}}",

    "sideBar.background": "{{colors.surface_container_lowest.default.hex}}",
    "sideBar.foreground": "{{colors.on_surface.default.hex}}",
    "sideBarTitle.foreground": "{{colors.on_surface.default.hex}}",
    "sideBarSectionHeader.background": "{{colors.surface_container_low.default.hex}}",

    "titleBar.activeBackground": "{{colors.surface_container_lowest.default.hex}}",
    "titleBar.activeForeground": "{{colors.on_surface.default.hex}}",
    "titleBar.inactiveBackground": "{{colors.surface_container_lowest.default.hex}}",

    "statusBar.background": "{{colors.surface_container_lowest.default.hex}}",
    "statusBar.foreground": "{{colors.on_surface_variant.default.hex}}",
    "statusBar.debuggingBackground": "{{colors.tertiary_container.default.hex}}",

    "tab.activeBackground": "{{colors.background.default.hex}}",
    "tab.activeForeground": "{{colors.on_surface.default.hex}}",
    "tab.inactiveBackground": "{{colors.surface_container_lowest.default.hex}}",
    "tab.inactiveForeground": "{{colors.on_surface_variant.default.hex}}",
    "tab.border": "{{colors.surface_container_lowest.default.hex}}",

    "panel.background": "{{colors.surface_container_lowest.default.hex}}",
    "panel.border": "{{colors.outline_variant.default.hex}}",
    "panelTitle.activeForeground": "{{colors.on_surface.default.hex}}",

    "input.background": "{{colors.surface_container_low.default.hex}}",
    "input.foreground": "{{colors.on_surface.default.hex}}",
    "input.border": "{{colors.outline_variant.default.hex}}",
    "input.placeholderForeground": "{{colors.on_surface_variant.default.hex}}",
    "inputOption.activeBorder": "{{colors.primary.default.hex}}",

    "dropdown.background": "{{colors.surface_container_low.default.hex}}",
    "dropdown.foreground": "{{colors.on_surface.default.hex}}",
    "dropdown.border": "{{colors.outline_variant.default.hex}}",

    "list.activeSelectionBackground": "{{colors.primary_container.default.hex}}",
    "list.activeSelectionForeground": "{{colors.on_primary_container.default.hex}}",
    "list.hoverBackground": "{{colors.surface_container.default.hex}}",
    "list.inactiveSelectionBackground": "{{colors.surface_container.default.hex}}",

    "button.background": "{{colors.primary.default.hex}}",
    "button.foreground": "{{colors.on_primary.default.hex}}",
    "button.hoverBackground": "{{colors.primary_container.default.hex}}",

    "badge.background": "{{colors.primary.default.hex}}",
    "badge.foreground": "{{colors.on_primary.default.hex}}",

    "scrollbarSlider.background": "{{colors.outline_variant.default.hex}}80",
    "scrollbarSlider.hoverBackground": "{{colors.outline_variant.default.hex}}",
    "scrollbarSlider.activeBackground": "{{colors.on_surface_variant.default.hex}}",

    "terminal.background": "{{colors.background.default.hex}}",
    "terminal.foreground": "{{colors.on_surface.default.hex}}"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "{{colors.outline_variant.default.hex}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "{{colors.primary.default.hex}}"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": {
        "foreground": "{{colors.tertiary.default.hex}}"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "{{colors.secondary.default.hex}}"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "{{colors.primary_container.default.hex}}"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "{{colors.secondary_container.default.hex}}"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "{{colors.on_surface.default.hex}}"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "{{colors.on_surface_variant.default.hex}}"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "{{colors.tertiary_container.default.hex}}"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "{{colors.secondary.default.hex}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "{{colors.on_surface_variant.default.hex}}"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "{{colors.tertiary.default.hex}}"
      }
    }
  ]
}
