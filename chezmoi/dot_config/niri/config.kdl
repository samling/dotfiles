// This config is in the KDL format: https://kdl.dev
// Split into modules under ~/.config/niri/modules/.
// Per-host monitor configuration lives under ~/.config/niri/hosts/<hostname>.kdl
// and is loaded by the optional includes below. Only the file matching the
// current host needs to exist; the rest are skipped with a warning.
//
// Check the wiki for a full description of the configuration:
// https://niri-wm.github.io/niri/Configuration:-Introduction

include "modules/input.kdl"

include optional=true "hosts/titan.kdl"

include "modules/layout.kdl"
include "modules/startup.kdl"
include "modules/window-rules.kdl"
include "modules/binds.kdl"
