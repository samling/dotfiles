#!/usr/bin/env bash
cat | jq --arg home "$HOME" '
  .statusLine = {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  }
  | .sandbox.seccomp.bpfPath   = "/usr/lib/claude-code-seccomp/unix-block.bpf"
  | .sandbox.seccomp.applyPath = "/usr/lib/claude-code-seccomp/apply-seccomp"
  | .sandbox.enabled = true
  | .sandbox.autoAllowBashIfSandboxed = true
  | .outputStyle = "sboynton"
  | .permissions = {
      "allow": [
        "Bash(find *)",
        "Bash(grep *)",
        "Bash(head *)",
        "Bash(kubectl get *)",
        "Bash(go get *)",
        "Bash(go mod *)",
        "Bash(make *)",
        "Bash(ls *)",
        "Bash(sed *)",
        "Bash(pkill *)",
        "Read",
        "Update",
        "WebFetch",
        "mcp__serena__list_dir",
        "mcp__serena__find_file",
