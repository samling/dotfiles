        "mcp__gitlab__gitlab_get_repo_tree",
        "mcp__gitlab__gitlab_greptile_ai_suggestions",
        "mcp__gitlab__gitlab_health",
        "mcp__gitlab__gitlab_list_commits",
        "mcp__gitlab__gitlab_list_epics",
        "mcp__gitlab__gitlab_list_issues",
        "mcp__gitlab__gitlab_list_merge_requests",
        "mcp__gitlab__gitlab_list_pipelines_jobs",
        "mcp__gitlab__gitlab_list_projects",
        "mcp__gitlab__gitlab_search_repositories",
