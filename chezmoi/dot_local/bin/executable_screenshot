#!/usr/bin/env bash
# Take a screenshot, pipe through satty for annotation. Saves PNG to
# ~/Pictures/Screenshots.
#
# Region capture goes through grim + slurp, querying niri for the focused
# output's logical scale so fractional displays produce native-resolution
# output. Window/monitor use niri's IPC directly (scale-correct internally).
#
# Usage: screenshot <region|window|monitor|all>

set -o errexit
set -o pipefail
set -o nounset

MODE="${1:-region}"
OUTPUT_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"
OUTPUT_FILE="${OUTPUT_DIR}/Screenshot-$(date +%Y-%m-%d-%H-%M-%S).png"

mkdir -p "$OUTPUT_DIR"

focused_scale() {
  niri msg --json focused-output | jq -r '.logical.scale // 1'
}

# niri msg returns before its screenshot UI writes the file, so poll the
# target path. Cap the wait so a cancelled selection doesn't hang forever.
wait_for_file() {
  local file=$1
  local timeout_s=${2:-120}
  local deadline=$(( $(date +%s) + timeout_s ))
  while [ "$(date +%s)" -lt "$deadline" ]; do
    [ -s "$file" ] && return 0
    sleep 0.1
  done
  return 1
}

capture_via_niri() {
  local action=$1
  local tmp
  tmp=$(mktemp --suffix=.png)
  trap 'rm -f "$tmp"' EXIT

  niri msg action "$action" --path "$tmp"
  if wait_for_file "$tmp"; then
    satty --filename "$tmp" --output-filename "$OUTPUT_FILE"
  fi
}

case "$MODE" in
  region)
    grim -s "$(focused_scale)" -g "$(slurp -d)" - \
      | satty --filename - --output-filename "$OUTPUT_FILE"
    ;;
  window)  capture_via_niri screenshot-window ;;
  monitor) capture_via_niri screenshot-screen ;;
  all)
    grim - | satty --filename - --output-filename "$OUTPUT_FILE"
    ;;
  *)
    echo "Unknown mode: $MODE (expected region|window|monitor|all)" >&2
    exit 1
    ;;
esac
